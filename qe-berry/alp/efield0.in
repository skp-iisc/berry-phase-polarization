&control
    calculation='scf'
    restart_mode='from_scratch',
    prefix='alp',
    lelfield=.true.,
    nberrycyc=1
    pseudo_dir='../../pseudo/',
    outdir='../tmp/'
    tprnfor=.true.
 /
 &system
    ibrav= 1, celldm(1)=10.28, nat=  8, ntyp= 2,
    ecutwfc = 40.0
 /
 &electrons
    diagonalization='david',
    conv_thr =  1.0d-8,
    mixing_beta = 0.5,
    startingwfc='random',
    efield_cart(1)=0.0d0,efield_cart(2)=0.0d0,efield_cart(3)=0.0d0
 /
ATOMIC_SPECIES
 Al  26.982 Al_ONCV_PBE-1.2.upf
 P  30.974 P_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS alat
 Al -0.125 -0.125 -0.125
 Al  0.375  0.375 -0.125
 Al  0.375 -0.125  0.375
 Al -0.125  0.375  0.375
 P  0.125  0.125  0.125
 P  0.625  0.625  0.125
 P  0.625  0.125  0.625
 P  0.125  0.625  0.625
K_POINTS {automatic}
4 4 4 0 0 0
